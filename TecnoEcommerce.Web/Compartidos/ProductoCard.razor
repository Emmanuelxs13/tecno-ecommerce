@using TecnoEcommerce.Modelos.DTOs

@*
    Tarjeta de producto enriquecida: badge, wishlist, rating, stock, ARIA.
    Principio OCP: parámetros externos controlan el comportamiento sin modificar el internals.
*@

<article class="card producto-card h-100 fade-in-up" aria-label="@Producto.Nombre">

    <!-- Imagen con overlay y botón wishlist -->
    <div class="card-img-wrapper" style="position:relative;">
        <!-- Badge dinámico -->
        @if (Producto.Stock == 0)
        {
            <span class="producto-badge badge-agotado" aria-label="Producto agotado">Agotado</span>
        }
        else if (Producto.Id % 4 == 0)
        {
            <span class="producto-badge badge-oferta" aria-label="En oferta">Oferta</span>
        }
        else if (Producto.Id % 3 == 0)
        {
            <span class="producto-badge badge-nuevo" aria-label="Producto nuevo">Nuevo</span>
        }

        <!-- Botón wishlist -->
        <button class="btn-wishlist @(_enWishlist ? "active" : "")"
                @onclick="ToggleWishlist"
                aria-label="@(_enWishlist ? "Quitar de favoritos" : "Agregar a favoritos")"
                aria-pressed="@_enWishlist">
            <i class="bi @(_enWishlist ? "bi-heart-fill" : "bi-heart")" aria-hidden="true"></i>
        </button>

        <img src="@(string.IsNullOrEmpty(Producto.ImagenUrl) ? "img/sin-imagen.png" : Producto.ImagenUrl)"
             class="card-img-top"
             alt="@Producto.Nombre"
             style="height:200px;object-fit:cover;display:block;width:100%;"
             loading="lazy" />
    </div>

    <div class="card-body d-flex flex-column p-3">

        <!-- Categoría -->
        <span class="producto-categoria-badge mb-2">
            <i class="bi bi-tag me-1" aria-hidden="true"></i>@Producto.NombreCategoria
        </span>

        <!-- Nombre -->
        <h3 class="card-title fw-bold mb-1" style="font-size:.95rem;line-height:1.35;">
            @Producto.Nombre
        </h3>

        <!-- Descripción corta -->
        <p class="card-text text-muted small flex-grow-1"
           style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;font-size:.82rem;">
            @Producto.Descripcion
        </p>

        <!-- Rating estático (basado en Id para demo) -->
        <div class="mb-2">
            <RatingEstrellas Valor="@_ratingDemo"
                             MostrarPuntuacion="true"
                             TotalResenas="@_resenasDemo" />
        </div>

        <!-- Precio y stock -->
        <div class="d-flex justify-content-between align-items-center mt-1 mb-3">
            <span class="producto-precio" aria-label="Precio: $@Producto.Precio.ToString("N2")">
                $@Producto.Precio.ToString("N2")
            </span>
            @if (Producto.Stock > 0)
            {
                <span class="badge" style="background:#dcfce7;color:#166534;font-weight:600;"
                      aria-label="@Producto.Stock unidades en stock">
                    @Producto.Stock en stock
                </span>
            }
            else
            {
                <span class="badge badge-cancelado" aria-label="Sin stock">Agotado</span>
            }
        </div>

        <!-- Botones -->
        <div class="d-flex gap-2" role="group" aria-label="Acciones para @Producto.Nombre">
            <a href="/producto/@Producto.Id"
               class="btn btn-outline-primary btn-sm flex-grow-1"
               aria-label="Ver detalle de @Producto.Nombre">
                <i class="bi bi-eye me-1" aria-hidden="true"></i>Ver
            </a>
            @if (Producto.Stock > 0)
            {
                <button class="btn btn-primary btn-sm flex-grow-1"
                        @onclick="() => OnAgregar.InvokeAsync(Producto.Id)"
                        disabled="@_agregando"
                        aria-label="Agregar @Producto.Nombre al carrito"
                        aria-busy="@_agregando">
                    @if (_agregando)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-cart-plus me-1" aria-hidden="true"></i>
                    }
                    Agregar
                </button>
            }
        </div>
    </div>
</article>

@code {
    /// <summary>Producto que se mostrará en la tarjeta.</summary>
    [Parameter, EditorRequired] public ProductoDto Producto { get; set; } = default!;

    /// <summary>Evento disparado al pulsar "Agregar al carrito".</summary>
    [Parameter] public EventCallback<int> OnAgregar { get; set; }

    private bool    _agregando;
    private bool    _enWishlist;

    // Rating demo determinístico basado en el Id del producto
    private decimal _ratingDemo  => 3.5m + (Producto.Id % 3) * 0.5m;
    private int     _resenasDemo => 12 + (Producto.Id * 7 % 43);

    private void ToggleWishlist() => _enWishlist = !_enWishlist;

    // Expone el estado de carga para que el padre pueda reiniciarlo si lo necesita
    public async Task SimularAgregar()
    {
        _agregando = true;
        StateHasChanged();
        await Task.Delay(600);
        _agregando = false;
    }
}

    {
        _agregando = true;
        await OnAgregar.InvokeAsync(Producto.Id);
        await Task.Delay(500);
        _agregando = false;
    }
}
