@using TecnoEcommerce.Modelos.DTOs

@*
    Tarjeta visual reutilizable para mostrar un producto en el catálogo.
    Principio OCP: acepta parámetros externos para personalizar su comportamiento
    sin modificar la implementación interna.
*@

<div class="card producto-card h-100">
    <!-- Imagen del producto -->
    <img src="@(string.IsNullOrEmpty(Producto.ImagenUrl) ? "img/sin-imagen.png" : Producto.ImagenUrl)"
         class="card-img-top" alt="@Producto.Nombre" style="height:200px;object-fit:cover;" />

    <div class="card-body d-flex flex-column p-3">
        <!-- Categoría -->
        <span class="producto-categoria-badge mb-2">
            <i class="bi bi-tag me-1"></i>@Producto.NombreCategoria
        </span>

        <!-- Nombre -->
        <h6 class="card-title fw-bold mb-1" style="font-size:.95rem; line-height:1.35;">
            @Producto.Nombre
        </h6>

        <!-- Descripción corta -->
        <p class="card-text text-muted small flex-grow-1"
           style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden; font-size:.82rem;">
            @Producto.Descripcion
        </p>

        <!-- Precio y stock -->
        <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
            <span class="producto-precio">$@Producto.Precio.ToString("N2")</span>
            @if (Producto.Stock > 0)
            {
                <span class="badge" style="background:#dcfce7;color:#166534;font-weight:600;">@Producto.Stock en stock</span>
            }
            else
            {
                <span class="badge badge-cancelado">Agotado</span>
            }
        </div>

        <!-- Botones -->
        <div class="d-flex gap-2">
            <a href="/producto/@Producto.Id" class="btn btn-outline-primary btn-sm flex-grow-1">
                <i class="bi bi-eye me-1"></i>Ver
            </a>
            @if (Producto.Stock > 0)
            {
                <button class="btn btn-primary btn-sm flex-grow-1"
                        @onclick="() => OnAgregar.InvokeAsync(Producto.Id)"
                        disabled="@_agregando">
                    @if (_agregando)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-cart-plus me-1"></i>
                    }
                    Agregar
                </button>
            }
        </div>
    </div>
</div>

@code {
    /// <summary>Producto que se mostrará en la tarjeta.</summary>
    [Parameter, EditorRequired] public ProductoDto Producto { get; set; } = default!;

    /// <summary>Evento que se dispara cuando el usuario pulsa "Agregar al carrito".</summary>
    [Parameter] public EventCallback<int> OnAgregar { get; set; }

    /// <summary>Controla el estado de carga del botón agregar.</summary>
    private bool _agregando;

    /// <summary>Maneja el click de agregar mostrando feedback visual.</summary>
    private async Task AgregarAlCarrito()
    {
        _agregando = true;
        await OnAgregar.InvokeAsync(Producto.Id);
        await Task.Delay(500);
        _agregando = false;
    }
}
