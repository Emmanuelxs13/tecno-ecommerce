@*
    Placeholder de carga tipo "skeleton" para tarjetas de producto.
    Se muestra mientras los datos se están cargando, mejorando la percepción de velocidad.
    Principio OCP: configurable en cantidad de columnas; sin lógica propia.
*@

@for (int i = 0; i < Cantidad; i++)
{
    <div class="col">
        <div class="skeleton-card" aria-hidden="true">
            <div class="skeleton skeleton-img"></div>
            <div class="p-3">
                <div class="skeleton skeleton-text mb-2" style="width:50%"></div>
                <div class="skeleton skeleton-text"      style="width:85%"></div>
                <div class="skeleton skeleton-text"      style="width:70%"></div>
                <div class="skeleton skeleton-text-sm"   style="width:40%; margin-top:.75rem;"></div>
                <div class="d-flex gap-2 mt-3">
                    <div class="skeleton skeleton-btn flex-grow-1"></div>
                    <div class="skeleton skeleton-btn flex-grow-1"></div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Número de tarjetas skeleton a mostrar.</summary>
    [Parameter] public int Cantidad { get; set; } = 4;
}
