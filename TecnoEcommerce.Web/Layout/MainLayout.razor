@inherits LayoutComponentBase

@*
    Layout principal de la aplicación.
    Principio SRP: encapsula únicamente la estructura visual global (navbar + contenido + footer).
*@

<NavMenu />

<main class="container py-4">
    @Body
</main>

<!-- ═══════════════════════════════════════════════════════════════
     Footer enriquecido
     ═══════════════════════════════════════════════════════════════ -->
<footer class="site-footer">
    <div class="container footer-main">
        <div class="row g-5">

            <!-- Columna marca -->
            <div class="col-12 col-md-4 footer-brand-col">
                <a class="footer-brand" href="/">
                    <span class="brand-icon"><i class="bi bi-cpu-fill"></i></span>
                    TecnoEcommerce
                </a>
                <p class="footer-description">
                    Tu destino de confianza para tecnología de calidad. Envío rápido,
                    garantía oficial y el mejor servicio al cliente.
                </p>
                <div class="footer-social">
                    <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                    <a href="#" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                </div>
            </div>

            <!-- Columna tienda -->
            <div class="col-6 col-md-2">
                <div class="footer-col-title">Tienda</div>
                <ul class="footer-links">
                    <li><a href="/"><i class="bi bi-grid"></i>Catálogo</a></li>
                    <li><a href="/"><i class="bi bi-fire"></i>Ofertas</a></li>
                    <li><a href="/"><i class="bi bi-star"></i>Novedades</a></li>
                    <li><a href="/"><i class="bi bi-award"></i>Más vendidos</a></li>
                    <li><a href="/"><i class="bi bi-tags"></i>Marcas</a></li>
                </ul>
            </div>

            <!-- Columna cuenta -->
            <div class="col-6 col-md-2">
                <div class="footer-col-title">Mi cuenta</div>
                <ul class="footer-links">
                    <li><a href="/login"><i class="bi bi-box-arrow-in-right"></i>Iniciar sesión</a></li>
                    <li><a href="/registro"><i class="bi bi-person-plus"></i>Registrarse</a></li>
                    <li><a href="/carrito"><i class="bi bi-cart3"></i>Mi carrito</a></li>
                    <li><a href="/mis-pedidos"><i class="bi bi-bag-check"></i>Mis pedidos</a></li>
                    <li><a href="/"><i class="bi bi-heart"></i>Lista de deseos</a></li>
                </ul>
            </div>

            <!-- Columna soporte -->
            <div class="col-12 col-md-4">
                <div class="footer-col-title">Soporte</div>
                <ul class="footer-links mb-3">
                    <li><a href="#"><i class="bi bi-question-circle"></i>Centro de ayuda</a></li>
                    <li><a href="#"><i class="bi bi-truck"></i>Rastrear pedido</a></li>
                    <li><a href="#"><i class="bi bi-arrow-return-left"></i>Devoluciones</a></li>
                    <li><a href="#"><i class="bi bi-headset"></i>Contactar soporte</a></li>
                </ul>
                <!-- Métodos de pago -->
                <div class="footer-col-title">Métodos de pago</div>
                <div class="footer-payments">
                    <span>VISA</span>
                    <span>MC</span>
                    <span>AMEX</span>
                    <span>OXXO</span>
                    <span>SPEI</span>
                </div>
            </div>

        </div>
    </div>

    <hr class="footer-divider" />

    <!-- Footer bottom -->
    <div class="container">
        <div class="footer-bottom">
            <span>&copy; @DateTime.Now.Year TecnoEcommerce &mdash; Todos los derechos reservados.</span>
            <div class="footer-bottom-links">
                <a href="#">Privacidad</a>
                <a href="#">Términos</a>
                <a href="#">Cookies</a>
            </div>
        </div>
    </div>
</footer>
