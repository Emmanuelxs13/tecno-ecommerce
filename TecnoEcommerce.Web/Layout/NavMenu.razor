@inherits LayoutComponentBase
@using TecnoEcommerce.Web.Servicios
@implements IDisposable

@inject SesionServicio Sesion
@inject NavigationManager Navegacion

@*
    Menú de navegación principal.
    Principio SRP: solo gestiona la barra de navegación y el estado de sesión visible.
    Se suscribe a OnCambio para reaccionar cuando el usuario inicia o cierra sesión.
*@

<nav class="navbar navbar-expand-lg navbar-dark sticky-top navbar-tecno">
    <div class="container">
        <!-- Marca -->
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <span class="brand-icon"><i class="bi bi-cpu-fill"></i></span>
            TecnoEcommerce
        </a>

        <!-- Botón colapso móvil -->
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navPrincipal">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navPrincipal">
            <!-- Enlace catálogo -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        <i class="bi bi-grid-fill me-1"></i>Catálogo
                    </NavLink>
                </li>
            </ul>

            <!-- Acciones de usuario -->
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-1">

                @if (_autenticado)
                {
                    <!-- Carrito -->
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/carrito">
                            <i class="bi bi-cart3 fs-5"></i>
                        </NavLink>
                    </li>

                    <!-- Mis pedidos -->
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/mis-pedidos">
                            <i class="bi bi-bag-check me-1"></i>Mis pedidos
                        </NavLink>
                    </li>

                    <!-- Nombre + logout -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-1"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <span>@Sesion.UsuarioActual?.Nombre</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <button class="dropdown-item text-danger" @onclick="CerrarSesion">
                                    <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                </button>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesión
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link btn-nav-registro" href="/registro">
                            <i class="bi bi-person-plus me-1"></i>Registrarse
                        </NavLink>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@code {
    /// <summary>Refleja si hay un usuario autenticado en la sesión actual.</summary>
    private bool _autenticado;

    /// <inheritdoc/>
    protected override void OnInitialized()
    {
        _autenticado = Sesion.EstaAutenticado;
        Sesion.OnCambio += ActualizarEstado;
    }

    /// <summary>Actualiza la UI cuando cambia el estado de sesión.</summary>
    private void ActualizarEstado()
    {
        _autenticado = Sesion.EstaAutenticado;
        InvokeAsync(StateHasChanged);
    }

    /// <summary>Cierra la sesión del usuario y redirige al inicio.</summary>
    private void CerrarSesion()
    {
        Sesion.CerrarSesion();
        Navegacion.NavigateTo("/");
    }

    /// <inheritdoc/>
    public void Dispose()
    {
        Sesion.OnCambio -= ActualizarEstado;
    }
}
