@inherits LayoutComponentBase
@using TecnoEcommerce.Web.Servicios
@implements IDisposable

@inject SesionServicio     Sesion
@inject NavigationManager  Navegacion
@inject CarritoApiServicio CarritoServicio

<nav class="navbar navbar-expand-lg navbar-tecno">
    <div class="container">

        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <span class="brand-icon"><i class="bi bi-cpu-fill"></i></span>
            TecnoEcommerce
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#navPrincipal"
                aria-controls="navPrincipal" aria-expanded="false">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navPrincipal">

            <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-1">
                <li class="nav-item"><NavLink class="nav-link" href="/?cat=laptops">Laptops</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/?cat=smartphones">Smartphones</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/?cat=gaming">Gaming</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/?cat=accesorios">Accesorios</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/?cat=monitores">Monitores</NavLink></li>
            </ul>

            <form class="d-flex my-2 my-lg-0 navbar-search me-2" role="search"
                  @onsubmit="BuscarYNavegar" @onsubmit:preventDefault>
                <input class="form-control border-0" type="search"
                       placeholder="&#xF52A; Buscar productos…"
                       @bind="_terminoBusqueda" />
            </form>

            <ul class="navbar-nav mb-2 mb-lg-0 align-items-lg-center gap-1">

                @if (_autenticado)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link px-2" href="/carrito"
                                 title="@(_totalItems > 0 ? $"Carrito ({_totalItems})" : "Carrito")">
                            <span class="nav-cart-wrap">
                                <i class="bi bi-bag3 fs-6"></i>
                                @if (_totalItems > 0)
                                {
                                    <span class="cart-badge">@(_totalItems > 9 ? "9+" : _totalItems.ToString())</span>
                                }
                            </span>
                        </NavLink>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-1 px-2"
                           href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle fs-6"></i>
                            <span class="d-none d-lg-inline small">@Sesion.UsuarioActual?.Nombre</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <span class="dropdown-item-text small text-muted">
                                    @Sesion.UsuarioActual?.Email
                                </span>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><NavLink class="dropdown-item" href="/mis-pedidos"><i class="bi bi-bag-check me-2"></i>Mis pedidos</NavLink></li>
                            <li><NavLink class="dropdown-item" href="/carrito"><i class="bi bi-bag3 me-2"></i>Mi carrito</NavLink></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <button class="dropdown-item text-danger" @onclick="CerrarSesion">
                                    <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                </button>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <NavLink class="nav-link small" href="/login">
                            Iniciar sesión
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link btn-nav-registro" href="/registro">
                            Registrarse
                        </NavLink>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@code {
    private bool   _autenticado;
    private string _terminoBusqueda = string.Empty;
    private int    _totalItems;

    protected override async Task OnInitializedAsync()
    {
        _autenticado = Sesion.EstaAutenticado;
        Sesion.OnCambio += ActualizarEstado;
        await CargarTotalCarrito();
    }

    private async void ActualizarEstado()
    {
        _autenticado = Sesion.EstaAutenticado;
        await CargarTotalCarrito();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CargarTotalCarrito()
    {
        if (!Sesion.EstaAutenticado) { _totalItems = 0; return; }
        try
        {
            var carrito = await CarritoServicio.ObtenerCarritoAsync();
            _totalItems = carrito?.Items.Sum(i => i.Cantidad) ?? 0;
        }
        catch { _totalItems = 3; /* mock */ }
    }

    private void BuscarYNavegar()
    {
        if (!string.IsNullOrWhiteSpace(_terminoBusqueda))
        {
            Navegacion.NavigateTo($"/?q={Uri.EscapeDataString(_terminoBusqueda.Trim())}");
            _terminoBusqueda = string.Empty;
        }
    }

    private void CerrarSesion()
    {
        Sesion.CerrarSesion();
        Navegacion.NavigateTo("/");
    }

    public void Dispose() => Sesion.OnCambio -= ActualizarEstado;
}