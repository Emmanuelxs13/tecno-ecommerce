@page "/carrito"
@using TecnoEcommerce.Web.Servicios
@using TecnoEcommerce.Modelos.DTOs

@inject CarritoApiServicio CarritoServicio
@inject PedidoApiServicio  PedidoServicio
@inject SesionServicio     Sesion
@inject NavigationManager  Navegacion

@*
    Página del carrito de compras y confirmación de pedido.
    Principio SRP: gestiona los ítems del carrito y el proceso de checkout.
*@

<PageTitle>Mi carrito – TecnoEcommerce</PageTitle>

<CargandoSpinner Visible="@_cargando" />

<div class="hero-banner mb-4 d-flex align-items-center justify-content-between">
    <div>
        <h2 class="hero-title"><i class="bi bi-cart3 me-2"></i>Mi carrito</h2>
        <p class="hero-sub">Revisa y confirma tu pedido</p>
    </div>
    <i class="bi bi-bag hero-icon d-none d-md-block"></i>
</div>

@if (!Sesion.EstaAutenticado)
{
    <div class="text-center py-5">
        <i class="bi bi-person-lock display-4 text-muted"></i>
        <p class="mt-3 text-muted">Debes iniciar sesión para ver tu carrito.</p>
        <a href="/login" class="btn btn-primary">Iniciar sesión</a>
    </div>
}
else if (!_cargando)
{
    <MensajeAlerta Mensaje="@_mensaje" Tipo="@_tipoMensaje" OnCerrar="() => _mensaje = string.Empty" />

    @if (_carrito is null || _carrito.Items.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-cart-x"></i>
            <p>Tu carrito está vacío.</p>
            <a href="/" class="btn btn-outline-primary">Explorar catálogo</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Lista de ítems -->
            <div class="col-12 col-lg-7">
                @foreach (var item in _carrito.Items)
                {
                    <div class="carrito-item-card d-flex align-items-center gap-3">
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-semibold">@item.NombreProducto</h6>
                            <small class="text-muted">$@item.PrecioUnitario.ToString("N2") × @item.Cantidad</small>
                        </div>
                        <span class="fw-bold producto-precio">$@item.Subtotal.ToString("N2")</span>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => EliminarItem(item.Id)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
            </div>

            <!-- Resumen y checkout -->
            <div class="col-12 col-lg-5">
                <div class="carrito-resumen-card">
                    <h5 class="fw-bold mb-3"><i class="bi bi-receipt me-2 text-primary"></i>Resumen</h5>

                    @foreach (var item in _carrito.Items)
                    {
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>@item.NombreProducto × @item.Cantidad</span>
                            <span>$@item.Subtotal.ToString("N2")</span>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
                        <span>Total</span>
                        <span class="producto-precio">$@_carrito.Total.ToString("N2")</span>
                    </div>

                    <!-- Dirección de envío -->
                    <div class="mb-3">
                        <label class="form-label">Dirección de entrega</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                            <InputText @bind-Value="_direccion" class="form-control"
                                       placeholder="Calle, número, ciudad..." />
                        </div>
                    </div>

                    <button class="btn btn-primary w-100 py-2"
                            @onclick="ConfirmarPedido"
                            disabled="@(_confirmando || string.IsNullOrWhiteSpace(_direccion))">
                        @if (_confirmando)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-bag-check me-2"></i>
                        }
                        Confirmar pedido
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private CarritoDto? _carrito;
    private string      _direccion   = string.Empty;
    private bool        _cargando    = true;
    private bool        _confirmando;
    private string      _mensaje     = string.Empty;
    private string      _tipoMensaje = "info";

    /// <inheritdoc/>
    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { _cargando = false; return; }
        await CargarCarrito();
    }

    /// <summary>Carga el carrito del usuario autenticado.</summary>
    private async Task CargarCarrito()
    {
        _cargando = true;
        _carrito  = await CarritoServicio.ObtenerCarritoAsync();
        _cargando = false;
    }

    /// <summary>Elimina un ítem del carrito y recarga.</summary>
    private async Task EliminarItem(int itemId)
    {
        var resultado = await CarritoServicio.EliminarItemAsync(itemId);
        if (resultado is not null) _carrito = resultado;
        else { _tipoMensaje = "danger"; _mensaje = "No se pudo eliminar el artículo."; }
    }

    /// <summary>Crea el pedido y redirige al historial de pedidos.</summary>
    private async Task ConfirmarPedido()
    {
        _confirmando = true;
        var dto      = new CrearPedidoDto { DireccionEntrega = _direccion };
        var pedido   = await PedidoServicio.CrearPedidoAsync(dto);
        _confirmando = false;

        if (pedido is null)
        {
            _tipoMensaje = "danger";
            _mensaje     = "No se pudo procesar el pedido. Verifica el stock e inténtalo de nuevo.";
            return;
        }

        Navegacion.NavigateTo("/mis-pedidos");
    }
}
