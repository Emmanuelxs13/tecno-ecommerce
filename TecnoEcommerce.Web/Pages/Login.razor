@page "/login"
@using System.ComponentModel.DataAnnotations

@inject NavigationManager Navegacion

<PageTitle>Iniciar sesión — TecnoEcommerce</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">
        <!-- Header -->
        <div class="auth-card-header">
            <div style="font-size:2rem;margin-bottom:.5rem"><i class="bi bi-cpu-fill"></i></div>
            <h1>Inicia sesión</h1>
            <p>Accede a tu cuenta TecnoEcommerce</p>
            <ul class="auth-benefits mt-3">
                <li><i class="bi bi-check-circle-fill"></i> Revisa el estado de tus pedidos</li>
                <li><i class="bi bi-check-circle-fill"></i> Accede a ofertas exclusivas</li>
                <li><i class="bi bi-check-circle-fill"></i> Guarda tu lista de deseos</li>
            </ul>
        </div>

        <!-- Body -->
        <div class="auth-card-body">
            @if (!string.IsNullOrEmpty(_errorGlobal))
            {
                <div class="alert alert-danger py-2 mb-3" style="font-size:.85rem">
                    <i class="bi bi-exclamation-circle me-1"></i>@_errorGlobal
                </div>
            }
            @if (_loginExitoso)
            {
                <div class="alert alert-success py-2 mb-3" style="font-size:.85rem">
                    <i class="bi bi-check-circle-fill me-1"></i>¡Bienvenido de vuelta! Redirigiendo…
                </div>
            }

            <EditForm Model="_modelo" OnValidSubmit="IniciarSesion">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="email" class="form-label">Correo electrónico</label>
                    <input id="email" type="email" class="form-control" placeholder="tu@correo.com"
                           @bind="_modelo.Email" autocomplete="email" />
                    <ValidationMessage For="() => _modelo.Email" class="validation-message" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Contraseña</label>
                    <div class="password-wrapper">
                        <input id="password"
                               type="@(_mostrarPassword ? "text" : "password")"
                               class="form-control"
                               placeholder="••••••••"
                               @bind="_modelo.Password"
                               autocomplete="current-password" />
                        <button type="button" class="btn-toggle-pass"
                                @onclick="() => _mostrarPassword = !_mostrarPassword"
                                title="@(_mostrarPassword ? "Ocultar" : "Ver") contraseña">
                            <i class="bi @(_mostrarPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="() => _modelo.Password" class="validation-message" />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="recordar" @bind="_recordarme" />
                        <label class="form-check-label" for="recordar" style="font-size:.85rem">Recuérdame</label>
                    </div>
                    <a href="#" style="font-size:.82rem">¿Olvidaste tu contraseña?</a>
                </div>

                <button type="submit" class="btn-apple btn-apple-primary btn-apple-wide" disabled="@_cargando">
                    @if (_cargando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    Iniciar sesión
                </button>
            </EditForm>

            <div class="auth-social-divider">o continúa con</div>

            <div class="d-flex gap-2">
                <button class="btn-apple btn-apple-white flex-fill" style="font-size:.82rem">
                    <i class="bi bi-google me-1"></i> Google
                </button>
                <button class="btn-apple btn-apple-white flex-fill" style="font-size:.82rem">
                    <i class="bi bi-apple me-1"></i> Apple
                </button>
            </div>

            <p class="text-center mt-4 mb-0" style="font-size:.85rem;color:var(--apple-gray)">
                ¿No tienes cuenta?
                <a href="/registro" style="font-weight:600">Regístrate gratis</a>
            </p>
        </div>
    </div>
</div>

@code {
    private class LoginModelo
    {
        [Required(ErrorMessage = "El correo es obligatorio")]
        [EmailAddress(ErrorMessage = "Correo no válido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria")]
        [MinLength(6, ErrorMessage = "Mínimo 6 caracteres")]
        public string Password { get; set; } = string.Empty;
    }

    private readonly LoginModelo _modelo = new();
    private bool   _cargando       = false;
    private bool   _mostrarPassword = false;
    private bool   _recordarme      = false;
    private bool   _loginExitoso    = false;
    private string _errorGlobal     = string.Empty;

    private async Task IniciarSesion()
    {
        _cargando = true;
        _errorGlobal = string.Empty;
        await Task.Delay(900);
        // Mock: cualquier email/password válidos entran
        _cargando = false;
        _loginExitoso = true;
        await Task.Delay(1200);
        Navegacion.NavigateTo("/");
    }
}