@page "/login"
@using TecnoEcommerce.Web.Servicios
@using TecnoEcommerce.Modelos.DTOs

@inject UsuarioApiServicio UsuarioServicio
@inject NavigationManager Navegacion
@inject SesionServicio    Sesion

@*
    Página de inicio de sesión.
    Principio SRP: única responsabilidad de autenticar al usuario.
*@

<PageTitle>Iniciar sesión – TecnoEcommerce</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card shadow-lg">
        <!-- Header con gradiente -->
        <div class="auth-card-header">
            <div style="font-size:2.5rem; margin-bottom:.5rem;"><i class="bi bi-cpu-fill"></i></div>
            <h4>Bienvenido de nuevo</h4>
            <p>Inicia sesión para continuar</p>
        </div>

        <div class="auth-card-body">
            <MensajeAlerta Mensaje="@_error" Tipo="danger" OnCerrar="() => _error = string.Empty" />

            <EditForm Model="@_modelo" OnValidSubmit="IniciarSesion">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Correo electrónico</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <InputText @bind-Value="_modelo.Email" class="form-control"
                                   placeholder="correo@ejemplo.com" type="email" />
                    </div>
                    <ValidationMessage For="() => _modelo.Email" class="validation-message" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <InputText @bind-Value="_modelo.Contrasena" class="form-control"
                                   placeholder="••••••••" type="password" />
                    </div>
                    <ValidationMessage For="() => _modelo.Contrasena" class="validation-message" />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2" disabled="@_cargando">
                    @if (_cargando)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Entrar
                </button>
            </EditForm>

            <hr class="my-3" />
            <p class="text-center text-muted small mb-0">
                ¿No tienes cuenta?
                <a href="/registro" class="fw-semibold">Regístrate aquí</a>
            </p>
        </div>
    </div>
</div>

@code {
    /// <summary>Modelo de formulario enlazado con EditForm.</summary>
    private readonly LoginUsuarioDto _modelo = new();

    /// <summary>Mensaje de error visible al usuario.</summary>
    private string _error = string.Empty;

    /// <summary>Indica si hay una petición en curso.</summary>
    private bool _cargando;

    /// <summary>Redirige si ya está autenticado.</summary>
    protected override void OnInitialized()
    {
        if (Sesion.EstaAutenticado) Navegacion.NavigateTo("/");
    }

    /// <summary>Envía las credenciales a la API y gestiona el resultado.</summary>
    private async Task IniciarSesion()
    {
        _cargando = true;
        _error    = string.Empty;

        var resultado = await UsuarioServicio.LoginAsync(_modelo);
        _cargando = false;

        if (resultado is null)
        {
            _error = "Correo o contraseña incorrectos.";
            return;
        }

        Navegacion.NavigateTo("/");
    }
}
