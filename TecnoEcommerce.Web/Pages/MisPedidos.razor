@page "/mis-pedidos"
@using TecnoEcommerce.Web.Servicios
@using TecnoEcommerce.Modelos.DTOs
@using TecnoEcommerce.Modelos.Enumeraciones

@inject PedidoApiServicio PedidoServicio
@inject SesionServicio    Sesion
@inject NavigationManager Navegacion

@*
    Página de historial de pedidos del usuario autenticado.
    Principio SRP: única responsabilidad de listar y mostrar el estado de los pedidos.
*@

<PageTitle>Mis pedidos – TecnoEcommerce</PageTitle>

<!-- ── Encabezado ────────────────────────────────────────────────────────── -->
<div class="mis-pedidos-header">
    <div>
        <h1 class="mis-pedidos-title">
            <i class="bi bi-bag-check me-2" aria-hidden="true"></i>Mis pedidos
        </h1>
        <p class="mis-pedidos-sub">Revisa el estado y el detalle de cada pedido</p>
    </div>
    <i class="bi bi-box-seam hero-icon d-none d-md-block" aria-hidden="true"></i>
</div>

@if (_cargando)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando pedidos…</span>
        </div>
    </div>
}
else if (!Sesion.EstaAutenticado)
{
    <div class="carrito-vacio" role="alert">
        <div class="carrito-vacio-icon">
            <i class="bi bi-person-lock" aria-hidden="true"></i>
        </div>
        <h4>Inicia sesión para ver tus pedidos</h4>
        <p class="text-muted">Necesitas una cuenta activa para acceder a tu historial.</p>
        <a href="/login" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>Iniciar sesión
        </a>
    </div>
}
else if (_pedidos.Count == 0)
{
    <div class="carrito-vacio">
        <div class="carrito-vacio-icon">
            <i class="bi bi-inbox" aria-hidden="true"></i>
        </div>
        <h4>Aún no tienes pedidos</h4>
        <p class="text-muted">Explora el catálogo y realiza tu primera compra.</p>
        <a href="/" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-grid me-2" aria-hidden="true"></i>Explorar catálogo
        </a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var pedido in _pedidos)
        {
            <div class="col-12">
                <article class="pedido-card" aria-label="Pedido #@pedido.Id">

                    <!-- Header del pedido -->
                    <div class="pedido-header">
                        <div class="pedido-header-id">
                            <span class="pedido-num">#@pedido.Id</span>
                            <span class="pedido-fecha">@pedido.FechaCreacion.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                        <div class="d-flex gap-2 flex-wrap justify-content-end">
                            <span class="badge @ObtenerClasePedido(pedido.EstadoPedido)"
                                  aria-label="Estado del pedido: @pedido.EstadoPedido">
                                <i class="bi @ObtenerIconoPedido(pedido.EstadoPedido) me-1" aria-hidden="true"></i>
                                @pedido.EstadoPedido
                            </span>
                            <span class="badge @ObtenerClasePago(pedido.EstadoPago)"
                                  aria-label="Estado de pago: @pedido.EstadoPago">
                                <i class="bi bi-credit-card me-1" aria-hidden="true"></i>@pedido.EstadoPago
                            </span>
                        </div>
                    </div>

                    <!-- Timeline de progreso -->
                    @if (pedido.EstadoPedido != EstadoPedido.Cancelado)
                    {
                        <nav class="pedido-timeline" aria-label="Progreso del pedido #@pedido.Id">
                            @foreach (var paso in _pasosTiempo)
                            {
                                <div class="timeline-step @((int)paso.Estado <= (int)pedido.EstadoPedido ? "active" : "") @(paso.Estado == pedido.EstadoPedido ? "current" : "")"
                                     aria-current="@(paso.Estado == pedido.EstadoPedido ? "step" : null)">
                                    <div class="timeline-dot">
                                        <i class="bi @paso.Icono" aria-hidden="true"></i>
                                    </div>
                                    <span class="timeline-label">@paso.Etiqueta</span>
                                </div>
                            }
                        </nav>
                    }
                    else
                    {
                        <div class="alert alert-danger small py-2 mx-3 mb-0 mt-2" role="alert">
                            <i class="bi bi-x-circle me-1" aria-hidden="true"></i>Este pedido fue cancelado.
                        </div>
                    }

                    <!-- Detalle de productos -->
                    <div class="pedido-body">
                        <ul class="list-unstyled mb-0" aria-label="Productos del pedido">
                            @foreach (var detalle in pedido.Detalles)
                            {
                                <li class="pedido-detalle-row">
                                    <span>@detalle.NombreProducto <span class="text-muted">×@detalle.Cantidad</span></span>
                                    <span>$@detalle.Subtotal.ToString("N2")</span>
                                </li>
                            }
                        </ul>
                        <div class="pedido-total-row">
                            <span>Total del pedido</span>
                            <span>$@pedido.Total.ToString("N2")</span>
                        </div>

                        <!-- Caja de envío -->
                        @if (!string.IsNullOrWhiteSpace(pedido.DireccionEntrega))
                        {
                            <div class="pedido-envio-box">
                                <i class="bi bi-geo-alt-fill me-2 text-primary" aria-hidden="true"></i>
                                <span>@pedido.DireccionEntrega</span>
                                @if (pedido.EstadoEnvio.HasValue)
                                {
                                    <span class="badge bg-info ms-2">@pedido.EstadoEnvio</span>
                                }
                            </div>
                        }
                    </div>

                </article>
            </div>
        }
    </div>
}

@code {
    private List<PedidoDto> _pedidos  = new();
    private bool            _cargando = true;

    private static readonly (EstadoPedido Estado, string Icono, string Etiqueta)[] _pasosTiempo =
    [
        (EstadoPedido.Pendiente,  "bi-clock",      "Pendiente"),
        (EstadoPedido.Procesando, "bi-gear",        "Procesando"),
        (EstadoPedido.Enviado,    "bi-truck",       "Enviado"),
        (EstadoPedido.Entregado,  "bi-house-check", "Entregado")
    ];

    /// <inheritdoc/>
    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { _cargando = false; return; }
        _pedidos  = await PedidoServicio.ObtenerMisPedidosAsync();
        _cargando = false;
    }

    /// <summary>Devuelve la clase CSS para el badge del estado de pedido.</summary>
    private static string ObtenerClasePedido(EstadoPedido estado) => estado switch
    {
        EstadoPedido.Pendiente   => "badge-pendiente",
        EstadoPedido.Procesando  => "badge-procesando",
        EstadoPedido.Enviado     => "badge-enviado",
        EstadoPedido.Entregado   => "bg-success",
        EstadoPedido.Cancelado   => "bg-danger",
        _                        => "bg-secondary"
    };

    /// <summary>Devuelve un icono Bootstrap para el estado del pedido.</summary>
    private static string ObtenerIconoPedido(EstadoPedido estado) => estado switch
    {
        EstadoPedido.Pendiente   => "bi-clock",
        EstadoPedido.Procesando  => "bi-gear-fill",
        EstadoPedido.Enviado     => "bi-truck",
        EstadoPedido.Entregado   => "bi-check-circle-fill",
        EstadoPedido.Cancelado   => "bi-x-circle-fill",
        _                        => "bi-question-circle"
    };

    /// <summary>Devuelve la clase CSS para el badge del estado de pago.</summary>
    private static string ObtenerClasePago(EstadoPago estado) => estado switch
    {
        EstadoPago.Aprobado  => "bg-success",
        EstadoPago.Rechazado => "bg-danger",
        _                    => "bg-warning text-dark"
    };
}

