    private MockProductoDetalle? _producto;
    private int    _cantidad = 1;
    private string _colorSeleccionado = string.Empty;
    private bool   _agregando = false;
    private bool   _mostrarToast = false;
    private string _mensajeToast = string.Empty;

    private List<MockRelacionado> _relacionados = new();

    protected override void OnParametersSet()
    {
        _catalogo.TryGetValue(Id, out _producto);
        _colorSeleccionado = _producto?.Colores.FirstOrDefault()?.Nombre ?? string.Empty;
        _cantidad = 1;
        _relacionados = _catalogo.Values
            .Where(p => p.Id != Id && p.CategoriaSlug == _producto?.CategoriaSlug)
            .Take(4)
            .Select(p => new MockRelacionado(p.Id, p.Nombre, p.Categoria, p.Precio, p.ImagenUrl))
            .ToList();
        if (_relacionados.Count < 4)
        {
            _relacionados.AddRange(_catalogo.Values
                .Where(p => p.Id != Id && !_relacionados.Any(r => r.Id == p.Id))
                .Take(4 - _relacionados.Count)
                .Select(p => new MockRelacionado(p.Id, p.Nombre, p.Categoria, p.Precio, p.ImagenUrl)));
        }
    }

    private async Task AgregarAlCarrito()
    {
        if (_producto == null) return;
        _agregando = true;
        await Task.Delay(600);
        _agregando = false;
        await MostrarToast($"✓ {_producto.Nombre} añadido al carrito");
    }

    private void ComprarAhora()
    {
        Navegacion.NavigateTo("/carrito");
    }

    private async Task MostrarToast(string msg)
    {
        _mensajeToast = msg;
        _mostrarToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        _mostrarToast = false;
        StateHasChanged();
    }
}