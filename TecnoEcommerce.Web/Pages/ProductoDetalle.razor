            new() { new("Onyx Black","#1c1c1e"), new("Marble Gray","#9b9590"), new("Cobalt Violet","#4d3f70"), new("Amber Yellow","#c8a84b") }),

        [4] = new(4, "ASUS VivoBook 15", "Laptops", "laptops", 899m, 0m, 0,
