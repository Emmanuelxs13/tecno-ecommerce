@page "/producto/{Id:int}"
@using TecnoEcommerce.Web.Servicios

@inject NavigationManager Navegacion

<PageTitle>@(_producto?.Nombre ?? "Producto") — TecnoEcommerce</PageTitle>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="py-2">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item"><a href="/?cat=@(_producto?.CategoriaSlug)">@(_producto?.Categoria)</a></li>
        <li class="breadcrumb-item active">@_producto?.Nombre</li>
    </ol>
</nav>

@if (_producto == null)
{
    <div class="skeleton-detalle">
        <div><div class="skeleton" style="height:460px;border-radius:18px"></div></div>
        <div class="ps-2">
            <div class="skeleton skeleton-text mb-3" style="width:60%;height:18px"></div>
            <div class="skeleton skeleton-text mb-2" style="width:90%;height:32px"></div>
            <div class="skeleton skeleton-text mb-4" style="width:40%;height:28px"></div>
            <div class="skeleton skeleton-text mb-2" style="height:16px"></div>
            <div class="skeleton skeleton-text mb-2" style="height:16px;width:80%"></div>
            <div class="skeleton skeleton-btn mt-4" style="height:52px"></div>
        </div>
    </div>
}
else
{
    <div class="detalle-wrapper">

        <!-- Imagen -->
        <div class="detalle-img-col">
            <div class="detalle-img">
                <img src="@_producto.ImagenUrl" alt="@_producto.Nombre"
                     onerror="this.src='https://placehold.co/600x600/f5f5f7/0071e3?text=@Uri.EscapeDataString(_producto.Nombre)'" />
            </div>
            <!-- Miniaturas colores / vistas -->
            <div class="d-flex gap-2 mt-3 justify-content-center flex-wrap">
                @foreach (var color in _producto.Colores)
                {
                    <button class="btn-apple @(_colorSeleccionado == color.Nombre ? "btn-apple-dark" : "btn-apple-white")"
                            style="width:40px;height:40px;padding:0;border-radius:50%"
                            @onclick="() => _colorSeleccionado = color.Nombre"
                            title="@color.Nombre">
                        <span style="display:block;width:20px;height:20px;background:@color.Hex;border-radius:50%;margin:auto"></span>
                    </button>
                }
            </div>
        </div>

        <!-- Info -->
        <div class="detalle-info-col">
            <div class="producto-categoria-badge">@_producto.Categoria</div>
            <h1 class="detalle-nombre">@_producto.Nombre</h1>

            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="rating-stars fs-6">★★★★@(_producto.Rating >= 4.5 ? "★" : "☆")</span>
                <span class="rating-score">@_producto.Rating — @_producto.Resenas.ToString("N0") reseñas</span>
            </div>

            <div class="detalle-precio">
                $@_producto.Precio.ToString("N2") USD
                @if (_producto.PrecioOriginal > 0)
                {
                    <span style="font-size:1rem;color:var(--apple-gray);text-decoration:line-through;margin-left:.5rem">
                        $@_producto.PrecioOriginal.ToString("N2")
                    </span>
                    <span class="badge ms-2" style="background:var(--apple-red);color:#fff;font-size:.75rem">
                        -@_producto.DescuentoPct%
                    </span>
                }
            </div>

            <p style="color:var(--apple-gray);font-size:.9rem;line-height:1.6;margin:.5rem 0 1rem">
                @_producto.Descripcion
            </p>

            <!-- Color seleccionado -->
            @if (_producto.Colores.Count > 1)
            {
                <div class="mb-3">
                    <span style="font-size:.85rem;font-weight:600">Color: </span>
                    <span style="font-size:.85rem;color:var(--apple-gray)">@_colorSeleccionado</span>
                </div>
            }

            <!-- Cantidad -->
            <div class="mb-3">
                <label class="form-label">Cantidad</label>
                <div class="qty-control">
                    <button class="qty-btn" @onclick="() => _cantidad = Math.Max(1, _cantidad-1)" disabled="@(_cantidad <= 1)">−</button>
                    <span class="qty-value">@_cantidad</span>
                    <button class="qty-btn" @onclick="() => _cantidad = Math.Min(10, _cantidad+1)" disabled="@(_cantidad >= 10)">+</button>
                </div>
            </div>

            <!-- Especificaciones -->
            <dl class="detalle-specs">
                @foreach (var s in _producto.Specs)
                {
                    <div class="spec-row">
                        <dt>@s.Key</dt>
                        <dd>@s.Value</dd>
                    </div>
                }
            </dl>

            <!-- CTA -->
            <div class="d-flex flex-column gap-2 mt-3">
                <button class="btn-agregar-carrito" @onclick="AgregarAlCarrito">
                    <i class="bi bi-cart3"></i>
                    @if (_agregando) { <span class="spinner-border spinner-border-sm"></span> }
                    else { <span>Agregar al carrito — $@((_producto.Precio * _cantidad).ToString("N2"))</span> }
                </button>
                <button class="btn-apple btn-apple-ghost btn-apple-wide" @onclick="ComprarAhora">
                    <i class="bi bi-lightning-charge-fill"></i> Comprar ahora
                </button>
            </div>

            <!-- Trust badges -->
            <div class="detalle-trust">
                <span><i class="bi bi-shield-check" style="color:#34c759"></i> Garantía oficial</span>
                <span><i class="bi bi-truck" style="color:var(--apple-blue)"></i> Envío en 24–48h</span>
                <span><i class="bi bi-arrow-return-left" style="color:#ff9f0a"></i> 30 días devolución</span>
                <span><i class="bi bi-lock-fill" style="color:var(--apple-gray)"></i> Pago seguro</span>
            </div>
        </div>
    </div>

    <!-- Recomendados -->
    <section class="py-3 mt-2">
        <div class="section-header">
            <h2 class="section-title">También te puede interesar</h2>
        </div>
        <div class="row g-3">
            @foreach (var p in _relacionados)
            {
                <div class="col-6 col-md-3">
                    <div class="producto-card cursor-pointer h-100" @onclick="() => Navegacion.NavigateTo($\"/producto/{p.Id}\")">
                        <img class="card-img-top" src="@p.ImagenUrl" alt="@p.Nombre"
                             onerror="this.src='https://placehold.co/400x300/f5f5f7/0071e3?text=TecnoE'" />
                        <div class="card-body">
                            <div class="producto-categoria-badge">@p.Categoria</div>
                            <h3 style="font-size:.9rem">@p.Nombre</h3>
                            <span class="producto-precio">$@p.Precio.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

@if (_mostrarToast)
{
    <div class="toast-container-custom">
        <div class="toast-item toast-success">
            <span class="toast-icon"><i class="bi bi-check-circle-fill" style="color:#34c759"></i></span>
            <span class="toast-text">@_mensajeToast</span>
        </div>
    </div>
}

@code {
