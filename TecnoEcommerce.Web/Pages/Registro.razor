@page "/registro"
@using System.ComponentModel.DataAnnotations

@inject NavigationManager Navegacion

<PageTitle>Crear cuenta — TecnoEcommerce</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card" style="max-width:480px">
        <!-- Header -->
        <div class="auth-card-header">
            <div style="font-size:2rem;margin-bottom:.5rem"><i class="bi bi-cpu-fill"></i></div>
            <h1>Crear cuenta</h1>
            <p>Únete a miles de clientes satisfechos</p>
            <ul class="auth-benefits mt-3">
                <li><i class="bi bi-check-circle-fill"></i> Envío gratis en tu primer pedido</li>
                <li><i class="bi bi-check-circle-fill"></i> Historial y seguimiento de pedidos</li>
                <li><i class="bi bi-check-circle-fill"></i> Ofertas y descuentos exclusivos</li>
                <li><i class="bi bi-check-circle-fill"></i> Lista de deseos personalizada</li>
            </ul>
        </div>

        <!-- Body -->
        <div class="auth-card-body">
            @if (_registroExitoso)
            {
                <div class="alert alert-success py-2 mb-3" style="font-size:.85rem">
                    <i class="bi bi-check-circle-fill me-1"></i>¡Cuenta creada! Redirigiendo al inicio…
                </div>
            }

            <EditForm Model="_modelo" OnValidSubmit="CrearCuenta">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" placeholder="Tu nombre"
                               @bind="_modelo.Nombre" autocomplete="given-name" />
                        <ValidationMessage For="() => _modelo.Nombre" class="validation-message" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Apellido</label>
                        <input type="text" class="form-control" placeholder="Tu apellido"
                               @bind="_modelo.Apellido" autocomplete="family-name" />
                        <ValidationMessage For="() => _modelo.Apellido" class="validation-message" />
                    </div>
                </div>

                <div class="mt-3">
                    <label class="form-label">Correo electrónico</label>
                    <input type="email" class="form-control" placeholder="tu@correo.com"
                           @bind="_modelo.Email" autocomplete="email" />
                    <ValidationMessage For="() => _modelo.Email" class="validation-message" />
                </div>

                <div class="mt-3">
                    <label class="form-label">Contraseña</label>
                    <div class="password-wrapper">
                        <input type="@(_verPwd1 ? "text" : "password")" class="form-control"
                               placeholder="Mínimo 8 caracteres"
                               @bind="_modelo.Password" autocomplete="new-password" />
                        <button type="button" class="btn-toggle-pass" @onclick="() => _verPwd1 = !_verPwd1">
                            <i class="bi @(_verPwd1 ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="() => _modelo.Password" class="validation-message" />
                </div>

                <div class="mt-3 mb-3">
                    <label class="form-label">Confirmar contraseña</label>
                    <div class="password-wrapper">
                        <input type="@(_verPwd2 ? "text" : "password")" class="form-control"
                               placeholder="Repite la contraseña"
                               @bind="_modelo.ConfirmarPassword" autocomplete="new-password" />
                        <button type="button" class="btn-toggle-pass" @onclick="() => _verPwd2 = !_verPwd2">
                            <i class="bi @(_verPwd2 ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="() => _modelo.ConfirmarPassword" class="validation-message" />
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="terminos" @bind="_aceptoTerminos" />
                    <label class="form-check-label" for="terminos" style="font-size:.82rem">
                        Acepto los <a href="#">términos y condiciones</a> y la <a href="#">política de privacidad</a>
                    </label>
                </div>

                <button type="submit" class="btn-apple btn-apple-primary btn-apple-wide" disabled="@(!_aceptoTerminos || _cargando)">
                    @if (_cargando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-person-plus me-1"></i> Crear mi cuenta
                </button>
            </EditForm>

            <p class="text-center mt-4 mb-0" style="font-size:.85rem;color:var(--apple-gray)">
                ¿Ya tienes cuenta?
                <a href="/login" style="font-weight:600">Iniciar sesión</a>
            </p>
        </div>
    </div>
</div>

@code {
    private class RegistroModelo
    {
        [Required(ErrorMessage = "El nombre es obligatorio")]
        public string Nombre { get; set; } = string.Empty;

        [Required(ErrorMessage = "El apellido es obligatorio")]
        public string Apellido { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo es obligatorio")]
        [EmailAddress(ErrorMessage = "Correo no válido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria")]
        [MinLength(8, ErrorMessage = "Mínimo 8 caracteres")]
        public string Password { get; set; } = string.Empty;

        [Compare(nameof(Password), ErrorMessage = "Las contraseñas no coinciden")]
        public string ConfirmarPassword { get; set; } = string.Empty;
    }

    private readonly RegistroModelo _modelo = new();
    private bool _cargando      = false;
    private bool _aceptoTerminos = false;
    private bool _registroExitoso = false;
    private bool _verPwd1 = false;
    private bool _verPwd2 = false;

    private async Task CrearCuenta()
    {
        _cargando = true;
        await Task.Delay(900);
        _cargando       = false;
        _registroExitoso = true;
        await Task.Delay(1400);
        Navegacion.NavigateTo("/");
    }
}